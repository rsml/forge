# Apple Developer credentials for signing + notarizing macOS releases.
# Copy to .env (gitignored) and fill in your value, then `make release`.
#
# APPLE_ID, APPLE_TEAM_ID, and SIGNING_IDENTITY are hardcoded in
# scripts/release.sh — none are secret. The app-specific password is the
# only real secret and belongs here.
#
# Generate it at https://appleid.apple.com
# (Sign-In and Security -> App-Specific Passwords).

APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
