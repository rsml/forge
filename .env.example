# Apple Developer credentials for signing + notarizing macOS releases.
# Copy to .env (gitignored) and fill in your values, then `make release`.
#
# APPLE_ID and APPLE_TEAM_ID are hardcoded in scripts/release.sh — neither
# is secret. Only the app-specific password and signing identity belong here.
#
# APPLE_APP_SPECIFIC_PASSWORD is generated at https://appleid.apple.com
# (Sign-In and Security -> App-Specific Passwords).
#
# SIGNING_IDENTITY must match a Developer ID Application certificate in
# your login keychain. List candidates with:
#   security find-identity -v -p codesigning

APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
SIGNING_IDENTITY="Developer ID Application: Your Name (XXXXXXXXXX)"
